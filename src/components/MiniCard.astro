---
// Compact card for a 'secondary' project.
interface Props {
  slug: string;
  title: string;
  kind: string;
  tagline: string;
  repo?: string;
  link?: string;
}
const { slug, title, kind, tagline, repo, link } = Astro.props;
const href = `/projects/${slug}`;
---

<article class="mini">
  <a class="cover" href={href} aria-label={`Read about ${title}`}></a>
  <div class="top">
    <h4 class="t">{title}</h4>
    <span class="k mono">{kind}</span>
  </div>
  <p class="d muted">{tagline}</p>
  <div class="foot">
    <a class="more" href={href}>Details →</a>
    {repo && <a class="ext mono" href={repo} target="_blank" rel="noopener">repo ↗</a>}
    {link && <a class="ext mono" href={link} target="_blank" rel="noopener">live ↗</a>}
  </div>
</article>

<style>
  .mini {
    position: relative;
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 1.4rem 1.5rem 1.2rem;
    background: var(--bg-tint);
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    transition: border-color 0.25s ease, transform 0.25s ease, background 0.25s ease;
  }
  .cover { position: absolute; inset: 0; z-index: 1; }
  .mini:hover { border-color: var(--accent); transform: translateY(-2px); }
  .top { display: flex; align-items: baseline; justify-content: space-between; gap: 0.75rem; }
  .t { font-size: var(--step-1); }
  .k { font-size: 0.66rem; letter-spacing: 0.06em; color: var(--accent); white-space: nowrap; }
  .d { font-size: 0.95rem; line-height: 1.5; }
  .foot { display: flex; gap: 1.1rem; margin-top: 0.4rem; position: relative; z-index: 2; }
  .more { font-family: var(--font-mono); font-size: 0.74rem; color: var(--ink); }
  .more:hover { color: var(--accent); }
  .ext { font-size: 0.72rem; color: var(--muted); }
  .ext:hover { color: var(--accent); }
</style>
