---
// Large editorial entry for a 'core' project, used on the home page.
interface Props {
  index: number;
  slug: string;
  title: string;
  kind: string;
  status: string;
  tagline: string;
  summary: string;
  stack: string[];
  metrics: { value: string; label: string }[];
}
const { index, slug, title, kind, status, tagline, summary, stack, metrics } = Astro.props;
const num = String(index).padStart(2, '0');
---

<article class="entry">
  <a class="entry-link" href={`/projects/${slug}`} aria-label={`Read the ${title} case study`}></a>
  <div class="rail">
    <span class="num">{num}</span>
    <span class="kind mono">{kind}</span>
    <span class="status mono">{status}</span>
  </div>
  <div class="body">
    <h3 class="title">{title} <span class="arrow" aria-hidden="true">→</span></h3>
    <p class="tagline">{tagline}</p>
    <p class="summary muted">{summary}</p>

    {metrics.length > 0 && (
      <div class="metrics">
        {metrics.map((m) => (
          <span class="stat"><span class="v">{m.value}</span><span class="l">{m.label}</span></span>
        ))}
      </div>
    )}

    <div class="stack">
      {stack.map((s) => <span class="tag">{s}</span>)}
    </div>
  </div>
</article>

<style>
  .entry {
    position: relative;
    display: grid;
    grid-template-columns: 8.5rem 1fr;
    gap: clamp(1rem, 4vw, 3rem);
    padding-block: clamp(2.2rem, 5vw, 3.4rem);
    border-top: 1px solid var(--rule);
  }
  .entry-link { position: absolute; inset: 0; z-index: 1; }
  .rail { display: flex; flex-direction: column; gap: 0.5rem; padding-top: 0.4rem; }
  .num {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 500;
    line-height: 1;
    color: var(--faint);
    transition: color 0.25s ease;
  }
  .kind { font-size: 0.74rem; letter-spacing: 0.05em; color: var(--accent); }
  .status { font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }

  .title {
    font-size: var(--step-2);
    display: flex; align-items: baseline; gap: 0.6rem;
  }
  .arrow { font-size: 0.7em; color: var(--accent); transform: translateX(0); transition: transform 0.25s ease; display: inline-block; }
  .tagline {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-top: 0.5rem;
    max-width: 30ch;
    color: var(--ink-soft);
  }
  .summary { margin-top: 1rem; max-width: 58ch; }

  .metrics { display: flex; flex-wrap: wrap; gap: 2.2rem; margin-top: 1.5rem; }

  .stack { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 1.4rem; position: relative; z-index: 2; }

  /* hover state driven by the whole card */
  .entry:hover .num { color: var(--accent); }
  .entry:hover .arrow { transform: translateX(6px); }
  .entry:hover .title { color: var(--accent); }

  @media (max-width: 680px) {
    .entry { grid-template-columns: 1fr; gap: 0.8rem; padding-block: 2rem; }
    .rail { flex-direction: row; align-items: baseline; gap: 1rem; }
    .num { font-size: 1.6rem; }
  }
</style>
