---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
---

<Base title={`${d.title} · Henry Bonikowsky`} description={d.summary}>
  <article class="project">
    <header class="phead">
      <div class="wrap">
        <a class="back" href="/#work">← All work</a>
        <p class="eyebrow">{d.kind} · {d.status}</p>
        <h1>{d.title}</h1>
        <p class="tagline">{d.tagline}</p>

        {d.metrics.length > 0 && (
          <div class="metrics">
            {d.metrics.map((m) => (
              <span class="stat"><span class="v">{m.value}</span><span class="l">{m.label}</span></span>
            ))}
          </div>
        )}

        <div class="meta">
          <div class="stack">
            {d.stack.map((s) => <span class="tag">{s}</span>)}
          </div>
          <div class="links">
            {d.repo && <a class="link mono" href={d.repo} target="_blank" rel="noopener">Repository ↗</a>}
            {d.link && <a class="link mono" href={d.link} target="_blank" rel="noopener">Live ↗</a>}
          </div>
        </div>
      </div>
    </header>

    <div class="wrap">
      <hr class="rule-accent" />
      <div class="prose">
        <Content />
      </div>
      <hr class="hr" />
      <a class="back-foot" href="/#work">← Back to all work</a>
    </div>
  </article>
</Base>

<style>
  .phead { padding-block: clamp(2rem, 6vw, 4rem) clamp(1.5rem, 4vw, 2.5rem); }
  .back, .back-foot {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
  }
  .back:hover, .back-foot:hover { color: var(--accent); }
  .phead .eyebrow { margin-top: 1.6rem; }
  .phead h1 { margin-top: 0.8rem; max-width: 18ch; }
  .tagline {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-2);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--ink-soft);
    margin-top: 1.1rem;
    max-width: 26ch;
  }
  .metrics { display: flex; flex-wrap: wrap; gap: 2.4rem; margin-top: 2rem; }
  .meta {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: 1rem; margin-top: 2rem;
  }
  .stack { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .links { display: flex; gap: 1.4rem; }

  .back-foot { display: inline-block; margin-block: 2.5rem 1rem; }

  /* ---- prose: the case-study body ---- */
  .prose { max-width: var(--measure); margin-top: 2.5rem; font-size: var(--step-0); }
  .prose :global(h2) {
    font-size: var(--step-2);
    margin-top: 3rem;
    margin-bottom: 0.9rem;
    letter-spacing: -0.015em;
  }
  .prose :global(h3) {
    font-size: var(--step-1);
    margin-top: 2.2rem;
    margin-bottom: 0.6rem;
  }
  .prose :global(p) { margin-bottom: 1.2rem; }
  .prose :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1.3rem 1.2rem; }
  .prose :global(li) { margin-bottom: 0.5rem; padding-left: 0.3rem; }
  .prose :global(li)::marker { color: var(--accent); }
  .prose :global(strong) { font-weight: 600; color: var(--ink); }
  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding: 0.2rem 0 0.2rem 1.3rem;
    margin: 1.6rem 0;
    font-style: italic;
    color: var(--ink-soft);
    font-size: var(--step-1);
    line-height: 1.4;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.86em;
    background: var(--bg-sunk);
    padding: 0.12em 0.4em;
    border-radius: 4px;
  }
  .prose :global(pre) {
    background: var(--bg-sunk);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 1.1rem 1.3rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.84rem;
    line-height: 1.6;
  }
  .prose :global(pre code) { background: none; padding: 0; }
  .prose :global(hr) { border: 0; height: 1px; background: var(--rule); margin: 2.5rem 0; }
  /* a "findings" table styling */
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.92rem; }
  .prose :global(th), .prose :global(td) { text-align: left; padding: 0.55rem 0.7rem; border-bottom: 1px solid var(--rule); }
  .prose :global(th) { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); font-weight: 500; }
</style>
